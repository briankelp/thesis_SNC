import sys
import pandas as pd
import numpy as np
from tensorflow import keras
from tensorflow.keras import layers
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
import os
import pickle


def _normalize_col(s: str) -> str:
    return s.strip().lower().replace(" ", "_")


def _resolve_column(df: pd.DataFrame, wanted: str) -> str:
    wanted_n = _normalize_col(wanted)
    for c in df.columns:
        if _normalize_col(c) == wanted_n:
            return c
    raise ValueError(f"Column '{wanted}' not found. Available: {list(df.columns)}")


def load_dataframe(csv_file: str, sequence_column: str, label_column: str) -> tuple[pd.DataFrame, str, str]:
    df = pd.read_csv(csv_file)
    seq_col = _resolve_column(df, sequence_column)
    lab_col = _resolve_column(df, label_column)
    return df, seq_col, lab_col


def build_sequence_dataset(
    df: pd.DataFrame,
    seq_col: str,
    lab_col: str
):
    feature_cols = [c for c in df.columns if c not in [seq_col, lab_col]]
    if not feature_cols:
        raise ValueError("No feature columns found after removing sequence and label columns.")

    x_list, y_list = [], []

    # one training sample = one sequence number
    for _, g in df.groupby(seq_col, sort=False):
        x = g[feature_cols].apply(pd.to_numeric, errors="coerce").fillna(-1).to_numpy(dtype=np.float32)

        # sequence-level label: 1 if any row in sequence is malicious, else 0
        y_raw = pd.to_numeric(g[lab_col], errors="coerce").fillna(0).to_numpy()
        y_seq = int((y_raw > 0).any())

        x_list.append(x)
        y_list.append(y_seq)

    if len(x_list) == 0:
        raise ValueError("No sequences found.")

    y = np.asarray(y_list, dtype=np.float32).reshape(-1, 1)

    n_seq = len(x_list)
    n_feat = x_list[0].shape[1]
    max_len_found = max(len(x) for x in x_list)

    print(f"Sequences: {n_seq}, Features: {n_feat}, Max length (raw): {max_len_found}")
    print(f"Label distribution: {np.unique(y, return_counts=True)}")
    return x_list, y, feature_cols


def scale_sequence_lists(x_train_list, x_test_list):
    scaler = StandardScaler()

    # fit only on real timesteps from training sequences (before padding)
    train_concat = np.concatenate(x_train_list, axis=0)
    scaler.fit(train_concat)

    x_train_scaled = [scaler.transform(x).astype(np.float32) for x in x_train_list]
    x_test_scaled = [scaler.transform(x).astype(np.float32) for x in x_test_list]
    return x_train_scaled, x_test_scaled, scaler


def pad_sequence_list(x_list, max_len=None, pad_value=0.0):
    if len(x_list) == 0:
        raise ValueError("Cannot pad an empty sequence list.")

    n_feat = x_list[0].shape[1]
    if max_len is None:
        max_len = max(len(x) for x in x_list)

    X = np.full((len(x_list), max_len, n_feat), pad_value, dtype=np.float32)
    for i, x in enumerate(x_list):
        L = min(len(x), max_len)
        X[i, :L, :] = x[:L, :]

    return X, max_len


def create_model(input_shape, lstm_units=128):
    inputs = keras.Input(shape=input_shape)
    x = layers.Masking(mask_value=0.0)(inputs)

    H = layers.LSTM(lstm_units, return_sequences=True)(x)
    context_seq = layers.Attention()([H, H])
    context_vec = layers.GlobalAveragePooling1D()(context_seq)
    h_pool = layers.GlobalMaxPooling1D()(H)

    combined = layers.Concatenate(axis=-1)([context_vec, h_pool])
    z = layers.Dense(lstm_units, activation="tanh")(combined)
    outputs = layers.Dense(1, activation="sigmoid")(z)

    return keras.Model(inputs, outputs)


def main(
    csv_file: str,
    sequence_column: str = "Sequence_Number",
    label_column: str = "label",
    max_len: int | None = None,
    lstm_units: int = 128,
    test_size: float = 0.2,
    random_state: int = 42,
    batch_size: int = 32,
    epochs: int = 10,
    save_dir: str = "artifacts"
):
    df, seq_col, lab_col = load_dataframe(csv_file, sequence_column, label_column)
    x_list, y, feature_cols = build_sequence_dataset(df, seq_col, lab_col)

    # split as list-of-sequences (variable length), not padded yet
    idx = np.arange(len(x_list))

    # safe stratify: only if each class has at least 2 samples
    y_flat = y.ravel().astype(int)
    unique, counts = np.unique(y_flat, return_counts=True)
    can_stratify = (len(unique) > 1) and np.all(counts >= 2)

    stratify_arg = y_flat if can_stratify else None
    if not can_stratify:
        print(
            f"Warning: stratified split disabled. Class counts={dict(zip(unique.tolist(), counts.tolist()))}. "
            "Need >=2 samples per class."
        )

    train_idx, test_idx = train_test_split(
        idx,
        test_size=test_size,
        random_state=random_state,
        stratify=stratify_arg
    )

    x_train_list = [x_list[i] for i in train_idx]
    x_test_list = [x_list[i] for i in test_idx]
    y_train = y[train_idx]
    y_test = y[test_idx]

    # scale BEFORE padding
    x_train_list, x_test_list, scaler = scale_sequence_lists(x_train_list, x_test_list)

    # choose max_len (global unless provided)
    used_max_len = max_len if max_len is not None else max(
        max(len(x) for x in x_train_list),
        max(len(x) for x in x_test_list)
    )

    # pad AFTER scaling with 0.0 so Masking(mask_value=0.0) works
    X_train, _ = pad_sequence_list(x_train_list, max_len=used_max_len, pad_value=0.0)
    X_test, _ = pad_sequence_list(x_test_list, max_len=used_max_len, pad_value=0.0)

    model = create_model((used_max_len, X_train.shape[2]), lstm_units=lstm_units)
    model.compile(optimizer="adam", loss="binary_crossentropy", metrics=["accuracy"])

    model.fit(
        X_train, y_train,
        epochs=epochs,
        batch_size=batch_size,
        validation_data=(X_test, y_test)
    )

    loss, acc = model.evaluate(X_test, y_test, batch_size=batch_size)
    print(f"Test Loss: {loss:.4f}, Test Accuracy: {acc:.4f}")

    save_artifacts(model, scaler, feature_cols, used_max_len, out_dir=save_dir)


def save_artifacts(model, scaler, feature_cols, max_len, out_dir="artifacts"):
    os.makedirs(out_dir, exist_ok=True)
    model.save(os.path.join(out_dir, "sequence_model.keras"))
    with open(os.path.join(out_dir, "preprocess.pkl"), "wb") as f:
        pickle.dump(
            {"scaler": scaler, "feature_cols": feature_cols, "max_len": int(max_len)},
            f
        )
    print(f"Saved artifacts to: {out_dir}")


def load_artifacts(artifacts_dir="artifacts"):
    model = keras.models.load_model(os.path.join(artifacts_dir, "sequence_model.keras"))
    with open(os.path.join(artifacts_dir, "preprocess.pkl"), "rb") as f:
        meta = pickle.load(f)
    return model, meta


def _resolve_many_columns(df: pd.DataFrame, expected_cols: list[str]) -> list[str]:
    resolved = []
    for c in expected_cols:
        resolved.append(_resolve_column(df, c))
    return resolved


def _align_features_to_training_schema(
    df: pd.DataFrame,
    expected_cols: list[str],
    fill_value: float = -1.0
) -> tuple[pd.DataFrame, list[str], list[str]]:
    # Normalize input names once
    norm_map = {_normalize_col(c): c for c in df.columns}
    expected_norm = [_normalize_col(c) for c in expected_cols]

    # Build a rename map for matched columns only
    rename_map = {}
    missing = []
    for exp, exp_n in zip(expected_cols, expected_norm):
        if exp_n in norm_map:
            rename_map[norm_map[exp_n]] = exp
        else:
            missing.append(exp)

    # Rename + one-shot reindex avoids fragmentation warnings
    aligned = (
        df.rename(columns=rename_map)
          .reindex(columns=expected_cols, fill_value=fill_value)
    )

    expected_set = set(expected_norm)
    extra = [c for c in df.columns if _normalize_col(c) not in expected_set]
    return aligned, missing, extra


def predict_csv(input_csv: str, artifacts_dir="artifacts", sequence_column="Sequence_Number", threshold=0.5):
    model, meta = load_artifacts(artifacts_dir)
    scaler = meta["scaler"]
    feature_cols = meta["feature_cols"]
    max_len = meta["max_len"]

    df_raw = pd.read_csv(input_csv)

    # Align once to training schema: missing -> fill, extra -> ignored
    aligned_df, missing_cols, extra_cols = _align_features_to_training_schema(
        df_raw, feature_cols, fill_value=-1.0
    )

    if missing_cols:
        print(f"Warning: {len(missing_cols)} trained features missing in input; filled with -1.")
    if extra_cols:
        print(f"Info: {len(extra_cols)} extra input columns ignored.")

    # if sequence column exists -> predict per sequence; else treat whole file as 1 sequence
    try:
        seq_col = _resolve_column(df_raw, sequence_column)
        groups = [idx for _, idx in df_raw.groupby(seq_col, sort=False).groups.items()]
    except ValueError:
        groups = [df_raw.index]

    x_list = []
    for idx in groups:
        g = aligned_df.loc[idx, feature_cols]
        x = g.apply(pd.to_numeric, errors="coerce").fillna(-1).to_numpy(dtype=np.float32)
        x = scaler.transform(x).astype(np.float32)
        x_list.append(x)

    X, _ = pad_sequence_list(x_list, max_len=max_len, pad_value=0.0)
    probs = model.predict(X, verbose=0).ravel()
    preds = (probs >= threshold).astype(int)

    out = pd.DataFrame({
        "sequence_index": np.arange(len(probs)),
        "probability": probs,
        "prediction": preds
    })
    print(out.to_string(index=False))


if __name__ == "__main__":
    # train:
    #   python stateful-lstm-by-sequence train <train_csv> [Sequence_Number] [label] [artifacts_dir]
    # infer:
    #   python stateful-lstm-by-sequence infer <input_csv> [artifacts_dir] [Sequence_Number]
    if len(sys.argv) < 3:
        print(
            f"Usage:\n"
            f"  {sys.argv[0]} train <train_csv> [Sequence_Number] [label] [artifacts_dir]\n"
            f"  {sys.argv[0]} infer <input_csv> [artifacts_dir] [Sequence_Number]"
        )
        sys.exit(1)

    mode = sys.argv[1].lower()

    if mode == "train":
        csv_path = sys.argv[2]
        seq_col = sys.argv[3] if len(sys.argv) > 3 else "Sequence_Number"
        lab_col = sys.argv[4] if len(sys.argv) > 4 else "label"
        out_dir = sys.argv[5] if len(sys.argv) > 5 else "artifacts"
        main(csv_path, sequence_column=seq_col, label_column=lab_col, save_dir=out_dir)

    elif mode == "infer":
        input_csv = sys.argv[2]
        artifacts_dir = sys.argv[3] if len(sys.argv) > 3 else "artifacts"
        seq_col = sys.argv[4] if len(sys.argv) > 4 else "Sequence_Number"
        predict_csv(input_csv, artifacts_dir=artifacts_dir, sequence_column=seq_col)

    else:
        print("First argument must be 'train' or 'infer'.")
        sys.exit(1)